---
---

<section class="bg-gradient-to-b from-white to-gray-50 py-20 px-5">
	<div class="max-w-4xl mx-auto">
		<!-- Header -->
		<div class="text-center mb-16">
			<h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">
				Valora Nuestra <span class="text-[#4e93ed]">Atención</span>
			</h2>
			<div class="h-1 w-16 bg-[#4e93ed] mx-auto"></div>
		</div>

		<!-- Contenedor Principal -->
		<div class="bg-white border border-gray-200 rounded-2xl p-12 md:p-16 shadow-md hover:shadow-lg transition-shadow duration-300">
			<div class="flex flex-col md:flex-row items-center justify-between gap-16">
				
				<!-- QR Container -->
				<div class="flex-shrink-0">
					<div class="w-72 h-72 bg-white border-2 border-black rounded-xl p-6 flex items-center justify-center">
						<img 
							src="/img/qr-code.png" 
							alt="Código QR - Reseñas en Google"
							class="w-64 h-64 object-contain"
						/>
					</div>
					<p class="text-center text-sm text-gray-600 mt-4 font-medium">
						Escanea con tu celular
					</p>
				</div>

				<!-- Contenido -->
				<div class="flex-1">
					<div class="mb-8">
						<p class="inline-block text-[#4e93ed] font-semibold text-sm tracking-wider mb-3 uppercase">
							Tu Opinión
						</p>
						<h3 class="text-2xl md:text-3xl font-bold text-gray-900 mb-4">
							Me gustaría saber cómo fue tu experiencia
						</h3>
						<p class="text-gray-700 text-lg leading-relaxed mb-6">
							Tus comentarios son valiosos para mí. Compártelos y ayúdame a seguir brindando una atención de calidad.
						</p>
					</div>

					<!-- Puntos clave -->
					<div class="space-y-4 mb-8">
						<div class="flex items-start gap-3">
							<svg class="w-5 h-5 text-[#4e93ed] mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
							</svg>
							<span class="text-gray-700">Tu opinión me ayuda a mejorar cada día</span>
						</div>
						<div class="flex items-start gap-3">
							<svg class="w-5 h-5 text-[#4e93ed] mt-1 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
								<path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
							</svg>
							<span class="text-gray-700">Tus comentarios motivan a otros pacientes a visitarme</span>
						</div>
					</div>

					
				</div>
			</div>
		</div>
	</div>
</section>



