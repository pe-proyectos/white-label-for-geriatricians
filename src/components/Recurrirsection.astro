            <!-- Columna Derecha: Tarjetas Escalonadas de Señales de Alarma -->
            <div class="w-full lg:w-1/2 flex flex-col justify-between">
                <div class="mb-6">
                    <h3 class="text-xl font-bold text-gray-800 mb-2">
