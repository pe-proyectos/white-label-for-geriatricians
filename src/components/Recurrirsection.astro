                    <p class="text-sm text-gray-500">
                        Si notas una o más de estas alertas, es el momento idóneo para una consulta médica especializada.
                    </p>
                </div>

                <!-- Las tarjetas en grid escalonado (staggered) -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 lg:gap-6 py-2">
                    
                    <!-- Tarjeta 1 -->
                    <div class="bg-white p-5 rounded-2xl shadow-sm border border-gray-100/80 hover:border-[#4e93ed]/40 hover:shadow-md transition duration-300 flex flex-col gap-2.5">
                        <div class="flex items-center gap-3">
