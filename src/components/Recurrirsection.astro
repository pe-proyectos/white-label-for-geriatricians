                            aria-label="Ir al Slide 3"
                            data-index="2"></button>
                        <button
                            type="button"
                            class="carousel-dot w-2.5 h-2.5 rounded-full bg-white/50 transition-all duration-300 cursor-pointer shadow-sm"
                            aria-label="Ir al Slide 4"
                            data-index="3"></button>
                    </div>
                </div>
