                    </div>

                    <!-- Tarjeta 3 -->
                    <div class="bg-white p-5 rounded-2xl shadow-sm border border-gray-100/80 hover:border-[#4e93ed]/40 hover:shadow-md transition duration-300 flex flex-col gap-2.5">
                        <div class="flex items-center gap-3">
                            <span class="flex items-center justify-center w-8 h-8 rounded-full bg-blue-50 text-[#4e93ed] font-bold text-sm">
                                3
                            </span>
                            <h4 class="font-bold text-gray-900 text-sm">Muchos medicamentos</h4>
                        </div>
                        <p class="text-xs text-gray-600 leading-relaxed">
                            Polifarmacia: toma diaria de múltiples fármacos que requieren revisión y supervisión.
                        </p>
                    </div>

                    <!-- Tarjeta 4 (Escalonada hacia abajo) -->
                    <div class="bg-white p-5 rounded-2xl shadow-sm border border-gray-100/80 hover:border-[#4e93ed]/40 hover:shadow-md transition duration-300 flex flex-col gap-2.5 sm:translate-y-4 lg:translate-y-6">
                        <div class="flex items-center gap-3">
