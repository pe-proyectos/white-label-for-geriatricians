                <!-- Mensaje inferior y Call to Action -->
                <div class="mt-8 sm:mt-12 p-5 bg-[#4e93ed]/10 border border-[#4e93ed]/20 rounded-2xl flex flex-col sm:flex-row items-center justify-between gap-4">
