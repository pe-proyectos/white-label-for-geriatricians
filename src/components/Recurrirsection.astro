        </div>

        <style>
            /* Ocultamos por completo las barras de desplazamiento */
            #astro-carousel {
                -ms-overflow-style: none; /* IE y Edge */
                scrollbar-width: none; /* Firefox */
            }
            #astro-carousel::-webkit-scrollbar {
                display: none; /* Chrome, Safari y Opera */
            }
        </style>

        <script>
            // Todo este código se ejecuta de forma segura en el cliente gracias a Astro
            const carousel = document.getElementById(
                "astro-carousel",
            ) as HTMLDivElement;
            const dots = document.querySelectorAll(
                ".carousel-dot",
            ) as NodeListOf<HTMLButtonElement>;

            let currentIndex = 0;
            const totalSlides = dots.length;
            const intervalTime = 5000; // 5 segundos para que dé tiempo a leer
            let autoPlayTimer: number;

            // Función para mover el carrusel a un índice específico
            function goToSlide(index: number) {
                if (!carousel) return;

                currentIndex = index;
                const slideWidth = carousel.offsetWidth;

                // Desplazamos horizontalmente el contenedor
                carousel.scrollTo({
                    left: slideWidth * index,
                    behavior: "smooth",
                });

                // Actualizamos los estilos visuales de los puntitos
                dots.forEach((dot, idx) => {
                    if (idx === index) {
                        dot.classList.remove("bg-white/50");
                        dot.classList.add("bg-white", "scale-125"); // El activo se hace un poco más grande
                    } else {
                        dot.classList.remove("bg-white", "scale-125");
                        dot.classList.add("bg-white/50");
                    }
                });
            }

            // Avanzar automáticamente
            function nextSlide() {
                const nextIndex = (currentIndex + 1) % totalSlides;
                goToSlide(nextIndex);
            }

            // Iniciar el temporizador
            function startAutoPlay() {
                autoPlayTimer = window.setInterval(nextSlide, intervalTime);
            }

            // Detener el temporizador (cuando el usuario interactúa manualmente)
            function stopAutoPlay() {
                clearInterval(autoPlayTimer);
            }

            // Eventos para los clics en los botones de abajo
            dots.forEach((dot) => {
                dot.addEventListener("click", (e) => {
                    const target = e.currentTarget as HTMLButtonElement;
                    const index = parseInt(
                        target.getAttribute("data-index") || "0",
                        10,
                    );

                    stopAutoPlay(); // Pausamos el auto-avance para no interrumpir al usuario
                    goToSlide(index);
                    startAutoPlay(); // Lo reanudamos
                });
            });

            // Detectar si el usuario desliza con el dedo (móviles) o scroll manual, para sincronizar los botones
            carousel?.addEventListener("scroll", () => {
                const slideWidth = carousel.offsetWidth;
                // Calculamos cuál es la página visible basándonos en la posición del scroll
                const newIndex = Math.round(carousel.scrollLeft / slideWidth);

                if (newIndex !== currentIndex && newIndex < totalSlides) {
                    currentIndex = newIndex;
                    dots.forEach((dot, idx) => {
                        if (idx === currentIndex) {
                            dot.classList.remove("bg-white/50");
                            dot.classList.add("bg-white", "scale-125");
                        } else {
                            dot.classList.remove("bg-white", "scale-125");
                            dot.classList.add("bg-white/50");
                        }
                    });
                }
            });

            // Encendemos el carrusel al cargar la página
            startAutoPlay();
        </script>
    </div>
</section>
