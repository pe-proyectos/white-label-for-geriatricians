---
import Footersection from "../components/Footersection.astro";
import Navbar from "../components/Navbar.astro";
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta
			name="description"
			content="Dr. Juan Andrés Jambo Mendoza - Geriatra Especialista en Jaén y Bagua. Experto en salud y bienestar del adulto mayor. Atención médica integral, personalizada y de calidad para un envejecimiento saludable y pleno. Consultas especializadas en geriatría."
		/>
		<meta
			name="keywords"
			content="geriatra, médico adulto mayor, especialista tercera edad, geriatría, medicina geriátrica, salud adulto mayor, bienestar ancianos, envejecimiento saludable, atención médica, consulta médica, valoración geriátrica, cuidado adulto mayor, medicina preventiva, salud integral, bienestar, longevidad, calidad de vida, Jaén, Bagua, Cajamarca, Chiclayo, Amazonas, Juan Jambo Mendoza"
		/>
		<meta name="author" content="Dr. Juan Andrés Jambo Mendoza" />
		<meta
			property="og:title"
			content="Dr. Juan Andrés Jambo Mendoza - Geriatra"
		/>
		<meta
			property="og:description"
			content="Dr. Juan Andrés Jambo Mendoza - Geriatra Especialista en Jaén y Bagua. Experto en salud y bienestar del adulto mayor. Atención médica integral, personalizada y de calidad para un envejecimiento saludable y pleno. Consultas especializadas en geriatría."
		/>
		<meta property="og:image" content="/img/drjuan_3.jpg" />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://geriatrajuanjambo.com" />
		<link rel="icon" type="image/png" sizes="64x64" href="/img/favicon64.png">
		<title>Dr. Juan Jambo Mendoza | Geriatra</title>
		
		<!-- Umami Analytics -->
		<script defer src="https://umami.luminari.agency/script.js" data-website-id="PLACEHOLDER_GERIATRAJUANJAMBO"></script>
		
		<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"
		></script>
		<style>
			/* Hide content until Tailwind loads */
			body {
				opacity: 0;
				transition: opacity 1s ease-in-out;
			}
			
			body.loaded {
				opacity: 1;
			}
		</style>
		<link
			rel="stylesheet"
			href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
			integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
			crossorigin=""
		/>
		<script
			src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
			integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
			crossorigin=""></script>
	</head>
	<body>
		<header>
			<Navbar />
		</header>
		<main>
			<slot />
		</main>
		<Footersection />
		
		<script>
			// Show content after 200ms to prevent FOUC
			setTimeout(() => {
				document.body.classList.add('loaded');
				
				// Ensure map is properly sized after content loads
				setTimeout(() => {
					if (window.mapita) {
						window.mapita.invalidateSize();
					}
				}, 100);
			}, 200);

			// ═══════════════════════════════════════════════════
			// UMAMI ANALYTICS - Event Tracking
			// ═══════════════════════════════════════════════════
			
			// Helper function to track events (waits for umami to load)
			function trackEvent(eventName) {
				if (typeof window.umami !== 'undefined') {
					window.umami.track(eventName);
				}
			}

			// 1. Scroll to Contact Section
			const contactSection = document.getElementById('contacto');
			if (contactSection) {
				const contactObserver = new IntersectionObserver((entries) => {
					entries.forEach(entry => {
						if (entry.isIntersecting) {
							trackEvent('scroll_to_contact');
							contactObserver.unobserve(entry.target);
						}
					});
				}, { threshold: 0.3 });
				contactObserver.observe(contactSection);
			}

			// 2. Click WhatsApp Buttons
			document.addEventListener('click', function(e) {
				const target = e.target.closest('a[href*="whatsapp"], button[id*="enviar"]');
				if (target && (target.href?.includes('whatsapp') || target.id?.includes('enviar'))) {
					trackEvent('click_whatsapp');
				}
			});

			// 3. Click Call Buttons
			document.addEventListener('click', function(e) {
				const target = e.target.closest('a[href^="tel:"]');
				if (target) {
					trackEvent('click_call');
				}
			});

			// 4. Form Start (onfocus on first field)
			let formStarted = false;
			const formInputs = document.querySelectorAll('#contacto input, #contacto select, #contacto textarea');
			formInputs.forEach(input => {
				input.addEventListener('focus', function() {
					if (!formStarted) {
						trackEvent('form_start');
						formStarted = true;
					}
				}, { once: true });
			});

			// 5. Form Submit (on send button click)
			const sendButton = document.getElementById('btn-enviar');
			if (sendButton) {
				sendButton.addEventListener('click', function(e) {
					// Get form values to validate before tracking
					const nombre = document.getElementById('inputNombre')?.value.trim();
					const dni = document.getElementById('inputDni')?.value.trim();
					const consulta = document.getElementById('consulta-select')?.value;
					if (nombre && dni && consulta && consulta !== 'Selecciona una opción') {
						trackEvent('form_submit');
					}
				});
			}
		</script>
	</body>
</html>
