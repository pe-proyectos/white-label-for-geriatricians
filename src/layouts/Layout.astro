---
import Footersection from "../components/Footersection.astro";
import Navbar from "../components/Navbar.astro";
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta
			name="description"
			content="Dr. Juan Andrés Jambo Mendoza - Geriatra Especialista en Jaén y Bagua. Experto en salud y bienestar del adulto mayor. Atención médica integral, personalizada y de calidad para un envejecimiento saludable y pleno. Consultas especializadas en geriatría."
		/>
		<meta
			name="keywords"
			content="geriatra, médico adulto mayor, especialista tercera edad, geriatría, medicina geriátrica, salud adulto mayor, bienestar ancianos, envejecimiento saludable, atención médica, consulta médica, valoración geriátrica, cuidado adulto mayor, medicina preventiva, salud integral, bienestar, longevidad, calidad de vida, Jaén, Bagua, Cajamarca, Chiclayo, Amazonas, Juan Jambo Mendoza"
		/>
		<meta name="author" content="Dr. Juan Andrés Jambo Mendoza" />
		<meta
			property="og:title"
			content="Dr. Juan Andrés Jambo Mendoza - Geriatra"
		/>
		<meta
			property="og:description"
			content="Dr. Juan Andrés Jambo Mendoza - Geriatra Especialista en Jaén y Bagua. Experto en salud y bienestar del adulto mayor. Atención médica integral, personalizada y de calidad para un envejecimiento saludable y pleno. Consultas especializadas en geriatría."
		/>
		<meta property="og:image" content="/img/drjuan_3.jpg" />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://geriatrajuanjambo.com" />
		<link rel="icon" type="image/png" sizes="64x64" href="/img/favicon64.png">
		<title>Dr. Juan Jambo Mendoza | Geriatra</title>
		
		<!-- Umami Analytics -->
		<script defer src="https://umami.luminari.agency/script.js" data-website-id="fd7f5460-d3c5-4449-9c24-1d1a9d160f27"></script>
		
		<script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"
		></script>
		<style>
			/* Hide content until Tailwind loads */
			body {
				opacity: 0;
				transition: opacity 1s ease-in-out;
			}
			
			body.loaded {
				opacity: 1;
			}
		</style>
		<link
			rel="stylesheet"
			href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css"
			integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY="
			crossorigin=""
		/>
		<script
			src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"
			integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo="
			crossorigin=""></script>
	</head>
	<body>
		<header>
			<Navbar />
		</header>
		<main>
			<slot />
		</main>
		<Footersection />
		
		<script>
			// Show content after 200ms to prevent FOUC
			setTimeout(() => {
				document.body.classList.add('loaded');
				
				// Ensure map is properly sized after content loads
				setTimeout(() => {
					if (window.mapita) {
						window.mapita.invalidateSize();
					}
				}, 100);
			}, 200);

			// ═══════════════════════════════════════════════════
			// UMAMI ANALYTICS - Event Tracking
			// ═══════════════════════════════════════════════════
			
			// Helper function to track events (waits for umami to load)
			function trackEvent(eventName) {
				if (typeof window.umami !== 'undefined') {
					window.umami.track(eventName);
				}
			}

			// 1. Scroll to Contact Section
			const contactSection = document.getElementById('contacto');
			if (contactSection) {
				const contactObserver = new IntersectionObserver((entries) => {
					entries.forEach(entry => {
						if (entry.isIntersecting) {
							trackEvent('scroll_to_contact');
							contactObserver.unobserve(entry.target);
						}
					});
				}, { threshold: 0.3 });
				contactObserver.observe(contactSection);
			}

			// 2. Click WhatsApp Buttons
			document.addEventListener('click', function(e) {
				const target = e.target.closest('a[href*="whatsapp"], button[id*="enviar"]');
				if (target && (target.href?.includes('whatsapp') || target.id?.includes('enviar'))) {
					trackEvent('click_whatsapp');
				}
			});

			// 3. Click Call Buttons
			document.addEventListener('click', function(e) {
				const target = e.target.closest('a[href^="tel:"]');
				if (target) {
					trackEvent('click_call');
				}
			});

			// 4. Form Start (onfocus on first field)
			let formStarted = false;
			const formInputs = document.querySelectorAll('#contacto input, #contacto select, #contacto textarea');
			formInputs.forEach(input => {
				input.addEventListener('focus', function() {
					if (!formStarted) {
						trackEvent('form_start');
						formStarted = true;
					}
				}, { once: true });
			});

			// 5. Form Submit (on send button click)
			const sendButton = document.getElementById('btn-enviar');
			if (sendButton) {
				sendButton.addEventListener('click', function(e) {
					// Get form values to validate before tracking
					const nombre = document.getElementById('inputNombre')?.value.trim();
					const dni = document.getElementById('inputDni')?.value.trim();
					const consulta = document.getElementById('consulta-select')?.value;
					if (nombre && dni && consulta && consulta !== 'Selecciona una opción') {
						trackEvent('form_submit');
					}
				});
			}

			// ═══════════════════════════════════════════════════
			// FLOATING WHATSAPP WIDGET
			// ═══════════════════════════════════════════════════
			const wsWidget = document.getElementById('whatsapp-widget');
			const wsBubble = document.getElementById('whatsapp-bubble');
			const wsBtn = document.getElementById('whatsapp-btn');

			if (wsWidget && wsBubble && wsBtn) {
				// Show widget after 1.5s
				setTimeout(() => {
					wsWidget.classList.remove('opacity-0', 'pointer-events-none');
					wsWidget.classList.add('opacity-100', 'pointer-events-auto');

					// Show bubble briefly
					setTimeout(() => {
						wsBubble.classList.remove('opacity-0', 'translate-x-4', 'scale-95');
						wsBubble.classList.add('opacity-100', 'translate-x-0', 'scale-100');

						// Hide bubble after 5s
						setTimeout(() => {
							wsBubble.classList.remove('opacity-100', 'translate-x-0', 'scale-100');
							wsBubble.classList.add('opacity-0', 'translate-x-4', 'scale-95');
						}, 5000);
					}, 500);
				}, 1500);

				// Hover actions on the green button
				wsBtn.addEventListener('mouseenter', () => {
					wsBubble.classList.remove('opacity-0', 'translate-x-4', 'scale-95');
					wsBubble.classList.add('opacity-100', 'translate-x-0', 'scale-100');
				});

				wsBtn.addEventListener('mouseleave', () => {
					wsBubble.classList.remove('opacity-100', 'translate-x-0', 'scale-100');
					wsBubble.classList.add('opacity-0', 'translate-x-4', 'scale-95');
				});
			}
		</script>

		<!-- Botón Flotante de WhatsApp -->
		<div id="whatsapp-widget" class="fixed bottom-6 right-6 z-50 flex items-center gap-3 transition-opacity duration-300 opacity-0 pointer-events-none">
			<!-- Burbuja de Mensaje (Tooltip) -->
			<div id="whatsapp-bubble" class="relative bg-white text-gray-800 text-sm font-medium py-2.5 px-4 rounded-2xl shadow-xl border border-gray-100 flex items-center gap-2 max-w-none transition-all duration-300 transform translate-x-4 opacity-0 scale-95 md:flex hidden whitespace-nowrap">
				<span>¡Hola! ¿En qué puedo ayudarle? 🩺</span>
				<!-- Flechita de la burbuja -->
				<div class="absolute right-[-6px] top-1/2 -translate-y-1/2 w-3 h-3 bg-white border-r border-t border-gray-100 rotate-45"></div>
			</div>

			<!-- Botón Contenedor -->
			<div class="relative group shrink-0" style="width: 56px !important; height: 56px !important;">
				<!-- Botón Principal -->
				<a 
					href="https://wa.me/51927357432" 
					target="_blank" 
					rel="noopener noreferrer" 
					class="bg-[#25D366] hover:bg-[#20ba5a] text-white rounded-full flex items-center justify-center shadow-lg hover:shadow-xl hover:shadow-green-500/20 hover:scale-110 transition duration-300 ease-in-out cursor-pointer"
					aria-label="Contactar por WhatsApp"
					id="whatsapp-btn"
					style="width: 56px !important; height: 56px !important; padding: 0 !important; display: flex !important; flex-shrink: 0 !important;"
				>
					<svg class="fill-current" viewBox="0 0 16 16" xmlns="http://www.w3.org/2000/svg" style="width: 28px !important; height: 28px !important; flex-shrink: 0 !important;">
						<path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"/>
					</svg>
				</a>
			</div>
		</div>
	</body>
</html>
